{
    "engine":
    {
        "enabled": true,
        "trap"   : true,

        "brain":
        {
            "code":
            {
                "ok"        : { "log":"TRACE",      "timeoutMcs":1000000 },
                "disabled"  : { "log":"TRACE",      "timeoutMcs":1000000 },
                "*"         : { "log":"ERROR",      "exit":true }
            }
        },

        "server":
        {
            "listen":
            {
                "port"                  :11121,
                "readWaitingTimeoutMcs" :1000000
            }
        }
    },

    "minWeight"         :0.000001,
    "maxWeight"         :1000,
    "maxError"          :10,
    "errorNormalize"    :0.11,
    "minNeuronPerThread":5,
    "maxThreadCount"    :3,

    "tickWrite"         :0,
    "tickChart"         :100,

    "dump":
    [
        {
            "enabled"       :true,
            "dumptype"      : "LAYER",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%.txt",
            "stages"        :[ "AFTER_FRONT" ],
            "layers"        :
            [
                "retina",
                "cortex_1",
                "cortex_2",
                "result",
                "sample",
                "error",
                "command"
            ],
            "data"          :[ "VALUES" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :true,
            "dumptype"      : "LAYER",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%.txt",
            "stages"        :[ "AFTER_BACK" ],
            "layers"        :
            [
                "cortex_1",
                "cortex_2",
                "result",
                "sample",
                "error",
                "bias",
                "command"
            ],
            "data"          :[ "ERRORS" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :true,
            "dumptype"      :"NERVE",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer-from%-%layer-to%.txt",
            "stages"        :[ "AFTER_LEARNING" ],
            "nerves"        :
            [
                [ "retina", "cortex_1" ],
                [ "cortex_1", "cortex_2" ],
                [ "cortex_2", "result" ]

            ],
            "data"          :[ "WEIGHTS" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :false,
            "dumptype"      :"NEURON",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer-from%-%layer-to%-%neuron%.txt",
            "stages"        :[ "AFTER_LEARNING" ],
            "neurons"       :
            {
                "cortex_1": [ [ 0,0,0 ], [ 1,0,0 ] ],
                "cortex_2": [ [ 0,0,0 ], [ 1,0,0 ] ]
            },
            "data"          :[ "WEIGHTS", "ERRORS", "VALUES" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :false,
            "pauseMcs"      :0,
            "stages"        :[ "AFTER_LEARNING" ],
            "lock"          :false,
            "precision"     :4
        }
    ]
}
