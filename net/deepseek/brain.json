{
    "engine":
    {
        "enabled": true,
        "trap"   : false,

        "brain":
        {
            "code":
            {
                "ok"        : { "log":"TRACE",      "timeoutMcs":1000000 },
                "disabled"  : { "log":"TRACE",      "timeoutMcs":1000000 },
                "*"         : { "log":"ERROR",      "exit":true }
            }
        },

        "server":
        {
            "listen":
            {
                "port"                  :11121,
                "readWaitingTimeoutMcs" :1000000
            }
        }
    },

    "minWeight"         :0.000001,
    "maxWeight"         :1000,
    "maxError"          :10,
    "errorNormalize"    :0.11,
    "minNeuronPerThread":5,
    "maxThreadCount"    :3,

    "tickWrite"         :0,
    "tickChart"         :100,

    "dump":
    [
        {
            "enabled"       :true,
            "lock"          :false,
            "pauseMcs"      :0,
            "stages"        :[ "AFTER_FRONT" ],
            "precision"     :4
        },

        {
            "enabled": false,
            "dumptype": "LAYERS",
            "file": "dump/layers.txt"
        },

        {
            "enabled"       :false,
            "dumptype"      : "LAYER",
            "file"          :"dump/%data%-%layer%.txt",
            "stages"        :[ "AFTER_FRONT" ],
            "layers"        :[ "sample" ],
            "data"          :[ "VALUES" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :true,
            "dumptype"      :"LAYER",
            "file"          :"dump/%data%-%layer%.txt",
            "stages"        :[ "AFTER_BACK" ],
            "layers"        :
            [
                "retina",
                "learning",
                "command",
                "result",
                "fc",
                "pool_2a","pool_2b","pool_2c","pool_2d",
                "pool_2e","pool_2f","pool_2g","pool_2h",
                "cortex_2a", "cortex_2b", "cortex_2c", "cortex_2g",
                "cortex_2e", "cortex_2f", "cortex_2g", "cortex_2h",
                "pool_1a","pool_1b","pool_1c","pool_1d",
                "cortex_1a", "cortex_1b", "cortex_1c", "cortex_1d",
                "sample"
            ],
            "data"          :[ "VALUES", "ERRORS" ],
            "dataview"      :"DIGIT",
            "precision"     :5
        },
        {
            "enabled"       :false,
            "dumptype"      :"NERVE",
            "file"          :"dump/%layer-from%-%layer-to%.txt",
            "stages"        :[ "AFTER_FRONT" ],
            "nerves"        :
            [
                [ "retina", "cortex_1a" ],
                [ "retina", "cortex_1b" ],
            ],
            "data"          :[ "WEIGHTS" ],
            "dataview"      :"DIGIT",
            "precision"     :2
        },
        {
            "enabled"       :true,
            "dumptype"      :"NEURON",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%-%neuron%.txt",
            "stages"        :[ "AFTER_FRONT" ],
            "neurons"       :
            {
                "cortex_1a": [[ 2,2,0 ]],
            },
            "data"          :[ "WEIGHTS" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },






        {
            "enabled"       :false,
            "dumptype"      : "LAYER",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%.txt",
            "stages"        :[ "AFTER_FRONT" ],
            "layers"        :
            [
                "retina",
                "cortex_1",
                "cortex_2",
                "result",
                "sample",
                "error",
                "command"
            ],
            "data"          :[ "VALUES" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :false,
            "dumptype"      : "LAYER",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%.txt",
            "stages"        :[ "AFTER_BACK" ],
            "layers"        :
            [
                "retina",
                "cortex_1",
                "cortex_2",
                "result",
                "sample",
                "error",
                "bias",
                "command"
            ],
            "data"          :[ "ERRORS" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        },
        {
            "enabled"       :false,
            "dumptype"      :"NERVE",
            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%-%layer-to%.txt",
            "stages"        :[ "AFTER_LEARNING" ],
            "nerves"        :
            [
                [ "retina", "cortex_1" ],
                [ "cortex_1", "cortex_2" ],
                [ "cortex_2", "result" ]
            ],
            "data"          :[ "WEIGHTS" ],
            "dataview"      :"DIGIT",
            "precision"     :4
        }
    ]
}

