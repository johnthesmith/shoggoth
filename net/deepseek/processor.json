{
    "engine":
    {
        "payloads":
        {
            "loader":
            {
                "enabled": true,
                "lib": "../../loader.so",
                "thread": true,
                "config":
                {
                    "log":
                    {
                        "trap": true
                    },
                    "code":
                    {
                        "ok":
                        {
                            "log":"TRACE",
                            "timeoutMcs":100000
                        }
                    },
                    "layers": {}
                },
            },

            "server":
            {
                "enabled": true,
                "lib": "../../server.so",
                "thread": true,
                "config":
                {
                    "log":
                    {
                        "trap": false
                    },
                    "code":
                    {
                        "ok":
                        {
                            "log":"TRACE",
                            "timeoutMcs":1000000
                        }
                    },
                    "port":11121,
                    "readWaitingTimeoutMcs" :1000000
                }
            },

            "processor":
            {
                "enabled": true,
                "lib": "../../processor.so",
                "thread": true,

                "config":
                {
                    "log":
                    {
                        "trap": true
                    },
                    "code":
                    {
                        "*": { "log":"TRACE", "timeoutMcs":1 }
                    },
                    "layers":
                    {
                        "let":
                        [
                            "cortex_1a", "cortex_1b", "cortex_1c", "cortex_1d",
                            "cortex_2a", "cortex_2b", "cortex_2c", "cortex_2d",
                            "cortex_2e", "cortex_2f", "cortex_2g", "cortex_2h",
                            "pool_1a", "pool_1b","pool_1c","pool_1d",
                            "pool_2a", "pool_2b","pool_2c","pool_2d",
                            "pool_2e", "pool_2f","pool_2g","pool_2h",
                            "fc",
                            "command",
                            "test_error",
                            "test_command"
                        ],
                        "read-values":
                        [
                            "retina", "learning", "bias", "sample"
                        ],
                        "write-values":
                        [
                            "learning", "result", "error"
                        ]
                    },

                    "mon":
                    {
                        "file": "processor.json",
                        "charts":
                        {
                            "values":
                            {
                                "retina": false,
                                "command": true
                            },
                            "errors":
                            {
                                "error": true
                            },
                            "ticks":
                            {
                            }
                        }
                    },
                    "dump":
                    [
                        {
                            "enabled"       :false,
                            "lock"          :true,
                            "pauseMcs"      :0,
                            "stages"        :[ "AFTER_FRONT" ]
                        },

                        {
                            "enabled": false,
                            "dumptype": "LAYERS",
                            "file": "dump/layers.txt"
                        },
                        {
                            "enabled"       :false,
                            "dumptype"      : "LAYER",
                            "file"          :"dump/%data%-%layer%.txt",
                            "stages"        :[ "AFTER_FRONT" ],
                            "layers"        :[ "sample" ],
                            "data"          :[ "VALUES" ],
                            "dataview"      :"DIGIT",
                            "precision"     :4
                        },
                        {
                            "enabled"       :true,
                            "dumptype"      :"LAYER",
                            "file"          :"dump/%data%-%layer%.txt",
                            "stages"        :[ "AFTER_BACK" ],
                            "layers"        :
                            [
                                "bias",
                                "retina",
                                "error",
                                "learning",
                                "command",
                                "result",
                                "sample"
                            ],
                            "reserv":
                            [
                                "retina",
                                "fc",
                                "pool_2a","pool_2b","pool_2c","pool_2d",
                                "pool_2e","pool_2f","pool_2g","pool_2h",
                                "cortex_2a", "cortex_2b", "cortex_2c", "cortex_2g",
                                "cortex_2e", "cortex_2f", "cortex_2g", "cortex_2h",
                                "pool_1a","pool_1b","pool_1c","pool_1d",
                                "cortex_1a", "cortex_1b", "cortex_1c", "cortex_1d"
                            ],
                            "data"          :[ "VALUES", "ERRORS" ],
                            "dataview"      :"DIGIT",
                            "precision"     :5
                        },
                        {
                            "enabled"       :false,
                            "dumptype"      :"NERVE",
                            "file"          :"dump/%layer-from%-%layer-to%.txt",
                            "stages"        :[ "AFTER_FRONT" ],
                            "nerves"        :
                            [
                                [ "retina", "cortex_1a" ],
                                [ "cortex_1a", "pool_1a" ],
                                [ "pool_1a", "cordex_2a" ],
                                [ "cortex_2a", "pool_2a" ],
                                [ "pool_2a", "fc" ],
                                [ "fc", "result" ]
                            ],
                            "data"          :[ "WEIGHTS" ],
                            "dataview"      :"DIGIT",
                            "precision"     :2
                        },
                        {
                            "enabled"       :false,
                            "dumptype"      :"NEURON",
                            "file"          :"dump/%dumptype%-%stage%-%data%-%layer%-%neuron%.txt",
                            "stages"        :[ "AFTER_FRONT" ],
                            "neurons"       :
                            {
                                "cortex_1a": [[ 2,2,0 ]]
                            },
                            "data"          :[ "WEIGHTS" ],
                            "dataview"      :"DIGIT",
                            "precision"     :4
                        }
                    ]
                }
            }
        }
    }
}
